{
    "version": "1.0.1",
    "name": "@bug-crusher/client-react",
    "main": "./lib/cjs/index.js",
    "module": "./lib/esm/index.js",
    "typings": "./lib/types/main.d.ts",
    "scripts": {
        "build": "yarn remove:lib && yarn copy:types && yarn build:esm && yarn build:cjs",
        "build:esm": "npx tsc -p tsconfig.json",
        "build:cjs": "npx tsc -p tsconfig-cjs.json",
        "remove:lib": "rm -rf lib",
        "copy:types": "npx copyfiles -u 1 \"types/**/*.d.ts\" \"lib/types/\"",
        "watch": "yarn watch:ts",
        "watch:ts": "npx tsc -w"
    },
    "license": "ISC",
    "peerDependencies": {
        "react": "*",
        "react-dom": "*"
    },
    "devDependencies": {
        "@bug-crusher/client-js": "^1.0.1",
        "@types/react": "^17.0.15",
        "@types/react-dom": "^17.0.9",
        "@typescript-eslint/eslint-plugin": "^4.28.5",
        "@typescript-eslint/parser": "^4.28.5",
        "copyfiles": "^2.4.1",
        "eslint": "^7.32.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-jest": "^24.4.0",
        "prettier": "^2.3.2",
        "typescript": "^4.3.5"
    },
    "files": [
        "lib"
    ],
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "bug",
        "crusher",
        "react"
    ],
    "author": "Nikola Marjanovic <nikola.marjanovic@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nikolamar/bugcrusher.git"
    },
    "bugs": {
        "url": "https://github.com/nikolamar/bugcrusher/issues"
    },
    "homepage": "https://github.com/nikolamar/bugcrusher#readme"
}
