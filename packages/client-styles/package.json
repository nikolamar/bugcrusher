{
    "version": "1.0.1",
    "name": "@bug-crusher/client-styles",
    "main": "lib/styles.css",
    "scripts": {
        "build": "yarn build:css",
        "build:css": "npx lessc src/styles.less lib/styles.css",
        "remove:lib": "rm -rf lib",
        "watch": "yarn watch:less",
        "watch:less": "npx less-watch-compiler src lib styles.less"
    },
