    "devDependencies": {
        "copyfiles": "^2.4.1",
        "less": "^4.1.1",
        "less-watch-compiler": "^1.16.2"
    },
    "files": [
        "lib"
    ],
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "bug",
        "crusher",
        "styles"
    ],
    "author": "Nikola Marjanovic <nikola.marjanovic@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nikolamar/bugcrusher.git"
    },
